type
    REFGUID = ^TGUID;

function ConstexprIsEqualGUID(a: REFGUID; b: REFGUID): boolean;


implementation



function ConstexprIsEqualGUID(a: REFGUID; b: REFGUID): boolean;
begin
    Result := (a^.Data1 = b^.Data1) and (a^.Data2 = b^.Data2) and (a^.Data3 = b^.Data3) and (a^.Data4[0] = b^.Data4[0]) and (a^.Data4[1] = b^.Data4[1]) and (a^.Data4[2] = b^.Data4[2]) and
        (a^.Data4[3] = b^.Data4[3]) and (a^.Data4[4] = b^.Data4[4]) and (a^.Data4[5] = b^.Data4[5]) and (a^.Data4[6] = b^.Data4[6]) and (a^.Data4[7] = b^.Data4[7]);
end;

