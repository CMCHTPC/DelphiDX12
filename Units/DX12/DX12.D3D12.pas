function D3D12_MAKE_COARSE_SHADING_RATE(x, y: longword): longword;
begin
    Result := (x shl D3D12_SHADING_RATE_X_AXIS_SHIFT or y);
end;



function D3D12_GET_COARSE_SHADING_RATE_X_AXIS(x: longword): longword;
begin
    Result := ((x shr D3D12_SHADING_RATE_X_AXIS_SHIFT) and D3D12_SHADING_RATE_VALID_MASK);
end;



function D3D12_GET_COARSE_SHADING_RATE_Y_AXIS(y: longword): longword;
begin
    Result := (y and D3D12_SHADING_RATE_VALID_MASK);
end;



function D3D12_DECODE_MIN_FILTER(D3D12Filter: longword): TD3D12_FILTER_TYPE;
begin
    Result := TD3D12_FILTER_TYPE((((D3D12Filter) shr D3D12_MIN_FILTER_SHIFT) and D3D12_FILTER_TYPE_MASK));
end;



function D3D12_DECODE_MAG_FILTER(D3D12Filter: longword): TD3D12_FILTER_TYPE;
begin
    Result :=
        TD3D12_FILTER_TYPE((((D3D12Filter) shr D3D12_MAG_FILTER_SHIFT) and D3D12_FILTER_TYPE_MASK));
end;



function D3D12_DECODE_MIP_FILTER(D3D12Filter: longword): TD3D12_FILTER_TYPE;
begin
    Result :=
        TD3D12_FILTER_TYPE((((D3D12Filter) shr D3D12_MIP_FILTER_SHIFT) and D3D12_FILTER_TYPE_MASK));
end;



function D3D12_DECODE_FILTER_REDUCTION(D3D12Filter: longword): TD3D12_FILTER_REDUCTION_TYPE;
begin
    Result :=
        TD3D12_FILTER_REDUCTION_TYPE((((D3D12Filter) shr D3D12_FILTER_REDUCTION_TYPE_SHIFT) and D3D12_FILTER_REDUCTION_TYPE_MASK));
end;



function D3D12_DECODE_IS_COMPARISON_FILTER(D3D12Filter: longword): boolean;
begin
    Result :=
        (D3D12_DECODE_FILTER_REDUCTION(D3D12Filter) = D3D12_FILTER_REDUCTION_TYPE_COMPARISON);
end;



function D3D12_DECODE_IS_ANISOTROPIC_FILTER(D3D12Filter: longword): boolean;
begin
    Result :=
        (((D3D12Filter and D3D12_ANISOTROPIC_FILTERING_BIT) = D3D12_ANISOTROPIC_FILTERING_BIT) and (D3D12_FILTER_TYPE_LINEAR = D3D12_DECODE_MIN_FILTER(D3D12Filter)) and (D3D12_FILTER_TYPE_LINEAR = D3D12_DECODE_MAG_FILTER(D3D12Filter)));
end;



function D3D12_ENCODE_BASIC_FILTER(min, mag, mip: TD3D12_FILTER_TYPE; reduction: longword): TD3D12_FILTER;
begin
    Result := TD3D12_FILTER((((Ord(min) and D3D12_FILTER_TYPE_MASK) shl D3D12_MIN_FILTER_SHIFT) or ((Ord(mag) and D3D12_FILTER_TYPE_MASK) shl D3D12_MAG_FILTER_SHIFT) or
        ((Ord(mip) and D3D12_FILTER_TYPE_MASK) shl D3D12_MIP_FILTER_SHIFT) or ((reduction and D3D12_FILTER_REDUCTION_TYPE_MASK) shl D3D12_FILTER_REDUCTION_TYPE_SHIFT)));
end;



function D3D12_ENCODE_ANISOTROPIC_FILTER(reduction: longword): TD3D12_FILTER;
begin
    Result := TD3D12_FILTER((Ord(D3D12_ANISOTROPIC_FILTERING_BIT) or Ord(D3D12_ENCODE_BASIC_FILTER(D3D12_FILTER_TYPE_LINEAR, D3D12_FILTER_TYPE_LINEAR, D3D12_FILTER_TYPE_LINEAR, reduction))));
end;



function D3D12_ENCODE_MIN_MAG_ANISOTROPIC_MIP_POINT_FILTER(reduction: longword): TD3D12_FILTER;
begin
    Result := TD3D12_FILTER((D3D12_ANISOTROPIC_FILTERING_BIT or Ord(D3D12_ENCODE_BASIC_FILTER(D3D12_FILTER_TYPE_LINEAR, D3D12_FILTER_TYPE_LINEAR, D3D12_FILTER_TYPE_POINT, reduction))));
end;



function D3D12_DECODE_SHADER_4_COMPONENT_MAPPING(ComponentToExtract, Mapping: longword): TD3D12_SHADER_COMPONENT_MAPPING;
begin
    Result := TD3D12_SHADER_COMPONENT_MAPPING((Mapping shr (D3D12_SHADER_COMPONENT_MAPPING_SHIFT * ComponentToExtract) and D3D12_SHADER_COMPONENT_MAPPING_MASK));
end;



function D3D12_ENCODE_SHADER_4_COMPONENT_MAPPING(Src0, Src1, Src2, Src3: longword): longword;
begin
    Result := (((Src0 and D3D12_SHADER_COMPONENT_MAPPING_MASK) or ((Src1 and D3D12_SHADER_COMPONENT_MAPPING_MASK) shl D3D12_SHADER_COMPONENT_MAPPING_SHIFT) or
        ((Src2 and D3D12_SHADER_COMPONENT_MAPPING_MASK) shl (D3D12_SHADER_COMPONENT_MAPPING_SHIFT * 2)) or ((Src3 and D3D12_SHADER_COMPONENT_MAPPING_MASK) shl (D3D12_SHADER_COMPONENT_MAPPING_SHIFT * 3)) or
        D3D12_SHADER_COMPONENT_MAPPING_ALWAYS_SET_BIT_AVOIDING_ZEROMEM_MISTAKES));
end;

