{ TD3D12_RESOURCE_BARRIER }

class operator TD3D12_RESOURCE_BARRIER.Initialize(var A: TD3D12_RESOURCE_BARRIER);
begin
    a.Init();
end;

class operator TD3D12_RESOURCE_BARRIER.Finalize(var A: TD3D12_RESOURCE_BARRIER);
begin
    if a.BarrierType = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION then
    begin
        // decrement ref counter
        if a.Transition.pResource <> nil then
            ID3D12Resource(a.Transition.pResource)._Release;
    end
    else if a.BarrierType = D3D12_RESOURCE_BARRIER_TYPE_ALIASING then
    begin
        // decrement ref counter
        if a.Aliasing.pResourceAfter <> nil then
            ID3D12Resource(a.Aliasing.pResourceAfter^)._Release;
        if a.Aliasing.pResourceBefore <> nil then
            ID3D12Resource(a.Aliasing.pResourceBefore^)._Release;

    end
    else if a.BarrierType = D3D12_RESOURCE_BARRIER_TYPE_UAV then
    begin
        // decrement ref counter
        if a.UAV.pResource <> nil then
            ID3D12Resource(a.UAV.pResource^)._Release;
    end;
end;

class function TD3D12_RESOURCE_BARRIER.Create(o: PD3D12_RESOURCE_BARRIER): PD3D12_RESOURCE_BARRIER;
begin
    New(Result);
    if o <> nil then
        // make a copy of the barrier
        Move(o^, Result^, SizeOf(TD3D12_RESOURCE_BARRIER));

    if Result^.BarrierType = D3D12_RESOURCE_BARRIER_TYPE_TRANSITION then
    begin
        // increment ref counter
        if Result^.Transition.pResource <> nil then
            ID3D12Resource(Result^.Transition.pResource)._AddRef;
    end
    else if Result^.BarrierType = D3D12_RESOURCE_BARRIER_TYPE_ALIASING then
    begin
        // increment ref counter
        if Result^.Aliasing.pResourceAfter <> nil then
            ID3D12Resource(Result^.Aliasing.pResourceAfter^)._AddRef;
        if Result^.Aliasing.pResourceBefore <> nil then
            ID3D12Resource(Result^.Aliasing.pResourceBefore^)._AddRef;

    end
    else if Result^.BarrierType = D3D12_RESOURCE_BARRIER_TYPE_UAV then
    begin
        // increment ref counter
        if Result^.UAV.pResource <> nil then
            ID3D12Resource(Result^.UAV.pResource^)._AddRef;
    end;
end;

class function TD3D12_RESOURCE_BARRIER.CreateTransition(constref pAResource: ID3D12Resource; AstateBefore: TD3D12_RESOURCE_STATES; AstateAfter: TD3D12_RESOURCE_STATES; Asubresource: UINT;
    Aflags: TD3D12_RESOURCE_BARRIER_FLAGS): PD3D12_RESOURCE_BARRIER;
begin
    New(Result);
    Result^.InitTransition(pAResource, AstateBefore, AstateAfter, Asubresource, Aflags);
end;

class function TD3D12_RESOURCE_BARRIER.CreateAliasing(pResourceBefore: ID3D12Resource; pResourceAfter: ID3D12Resource): PD3D12_RESOURCE_BARRIER;
begin
    New(Result);
    Result^.InitAliasing(pResourceBefore, pResourceAfter);
end;

class function TD3D12_RESOURCE_BARRIER.CreateUAV(constref pResource: ID3D12Resource): PD3D12_RESOURCE_BARRIER;
begin
    New(Result);
    Result^.InitUAV(pResource);
end;

procedure TD3D12_RESOURCE_BARRIER.Init();
begin
    ZeroMemory(@self, SizeOf(TD3D12_RESOURCE_BARRIER));
end;

procedure TD3D12_RESOURCE_BARRIER.InitTransition(constref pAResource: ID3D12Resource; AstateBefore: TD3D12_RESOURCE_STATES; AstateAfter: TD3D12_RESOURCE_STATES; Asubresource: UINT; Aflags: TD3D12_RESOURCE_BARRIER_FLAGS);
begin
    self.BarrierType := D3D12_RESOURCE_BARRIER_TYPE_TRANSITION;
    self.Flags := Aflags;
    self.Transition.pResource := PID3D12Resource(pAResource);
    if pAResource <> nil then
        pAResource._AddRef;
    self.Transition.StateBefore := AstateBefore;
    self.Transition.StateAfter := AstateAfter;
    self.Transition.Subresource := Asubresource;
end;

procedure TD3D12_RESOURCE_BARRIER.InitAliasing(constref pResourceBefore: ID3D12Resource; constref pResourceAfter: ID3D12Resource);
begin
    self.BarrierType := D3D12_RESOURCE_BARRIER_TYPE_ALIASING;
    self.Aliasing.pResourceBefore := PID3D12Resource(pResourceBefore);
    if pResourceBefore <> nil then
        pResourceBefore._AddRef;
    self.Aliasing.pResourceAfter := PID3D12Resource(pResourceAfter);
    if pResourceAfter <> nil then
        pResourceAfter._AddRef;
end;

procedure TD3D12_RESOURCE_BARRIER.InitUAV(constref pResource: ID3D12Resource);
begin
    self.BarrierType := D3D12_RESOURCE_BARRIER_TYPE_UAV;
    self.UAV.pResource := PID3D12Resource(pResource);
    if pResource <> nil then
        pResource._AddRef;
end;

