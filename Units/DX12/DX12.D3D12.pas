class function TD3D12_VIEWPORT.Create(topLeftX: single; topLeftY: single; Width: single; Height: single; minDepth: single; maxDepth: single): PD3D12_VIEWPORT;
begin
    New(Result);
    Result^.TopLeftX := topLeftX;
    Result^.TopLeftY := topLeftY;
    Result^.Width := Width;
    Result^.Height := Height;
    Result^.MinDepth := minDepth;
    Result^.MaxDepth := maxDepth;
end;

class function TD3D12_VIEWPORT.Create(pResource: ID3D12Resource; mipSlice: UINT; topLeftX: single; topLeftY: single; minDepth: single; maxDepth: single): PD3D12_VIEWPORT;
var
    Desc: TD3D12_RESOURCE_DESC;
    SubresourceWidth: uint64;
    SubresourceHeight: uint64;
begin
    New(Result);

    pResource.GetDesc(@Desc);

    SubresourceWidth := Desc.Width shr mipSlice;
    SubresourceHeight := Desc.Height shr mipSlice;
    case (Desc.Dimension) of

        D3D12_RESOURCE_DIMENSION_BUFFER:
        begin
            TopLeftX := topLeftX;
            TopLeftY := 0.0;
            Result^.Width := (Desc.Width) - topLeftX;
            Result^.Height := 1.0;
        end;
        D3D12_RESOURCE_DIMENSION_TEXTURE1D:
        begin
            TopLeftX := topLeftX;
            TopLeftY := 0.0;
            if SubresourceWidth <> 0 then
                Result^.Width := SubresourceWidth - topLeftX
            else
                Result^.Width := 1.0 - topLeftX;
            Result^.Height := 1.0;
        end;
        D3D12_RESOURCE_DIMENSION_TEXTURE2D,
        D3D12_RESOURCE_DIMENSION_TEXTURE3D:
        begin
            TopLeftX := topLeftX;
            TopLeftY := topLeftY;
            if SubresourceWidth <> 0 then
                Result^.Width := SubresourceWidth - topLeftX
            else
                Result^.Width := 1.0 - topLeftX;
            if SubresourceHeight <> 0 then
                Result^.Height := SubresourceHeight - topLeftY
            else
                Result^.Height := 1.0 - topLeftY;
        end;
    end;

    Result^.MinDepth := minDepth;
    Result^.MaxDepth := maxDepth;
end;

