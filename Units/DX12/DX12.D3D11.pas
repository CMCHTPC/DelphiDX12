{ TD3D11_SAMPLER_DESC }

class operator TD3D11_SAMPLER_DESC.Initialize(var aRec: TD3D11_SAMPLER_DESC);
begin
    aRec.Filter := D3D11_FILTER_MIN_MAG_MIP_LINEAR;
    aRec.AddressU := D3D11_TEXTURE_ADDRESS_CLAMP;
    aRec.AddressV := D3D11_TEXTURE_ADDRESS_CLAMP;
    aRec.AddressW := D3D11_TEXTURE_ADDRESS_CLAMP;
    aRec.MipLODBias := 0;
    aRec.MaxAnisotropy := 1;
    aRec.ComparisonFunc := D3D11_COMPARISON_NEVER;
    aRec.BorderColor[0] := 1.0;
    aRec.BorderColor[1] := 1.0;
    aRec.BorderColor[2] := 1.0;
    aRec.BorderColor[3] := 1.0;
    aRec.MinLOD := -3.402823466e+38; // -FLT_MAX
    aRec.MaxLOD := 3.402823466e+38; // FLT_MAX
end;



procedure TD3D11_SAMPLER_DESC.Init(filter: TD3D11_FILTER; addressU: TD3D11_TEXTURE_ADDRESS_MODE; addressV: TD3D11_TEXTURE_ADDRESS_MODE; addressW: TD3D11_TEXTURE_ADDRESS_MODE; mipLODBias: single;
    maxAnisotropy: UINT; comparisonFunc: TD3D11_COMPARISON_FUNC; borderColor: PSingle; minLOD: single; maxLOD: single);
begin
    Self.Filter := filter;
    Self.AddressU := addressU;
    Self.AddressV := addressV;
    Self.AddressW := addressW;
    Self.MipLODBias := mipLODBias;
    Self.MaxAnisotropy := maxAnisotropy;
    Self.ComparisonFunc := comparisonFunc;
    if (borderColor = nil) then
    begin
        Self.BorderColor[0] := 1.0;
        Self.BorderColor[1] := 1.0;
        Self.BorderColor[2] := 1.0;
        Self.BorderColor[3] := 1.0;
    end
    else
    begin
        Self.BorderColor[0] := borderColor[0];
        Self.BorderColor[1] := borderColor[1];
        Self.BorderColor[2] := borderColor[2];
        Self.BorderColor[3] := borderColor[3];
    end;
    MinLOD := minLOD;
end;

