function D3D11_ENCODE_ANISOTROPIC_FILTER(reduction: DWORD): TD3D11_FILTER;
function D3D11_DECODE_MIN_FILTER(d3d11Filter: DWORD): TD3D11_FILTER_TYPE;
function D3D11_DECODE_MAG_FILTER(d3d11Filter: DWORD): TD3D11_FILTER_TYPE;
function D3D11_DECODE_MIP_FILTER(d3d11Filter: DWORD): TD3D11_FILTER_TYPE;
function D3D11_DECODE_FILTER_REDUCTION(d3d11Filter: DWORD): TD3D11_FILTER_REDUCTION_TYPE;
function D3D11_DECODE_IS_COMPARISON_FILTER(d3d11Filter: DWORD): longbool;
function D3D11_DECODE_IS_ANISOTROPIC_FILTER(d3d11Filter: DWORD): longbool;

implementation

uses
    Windows.Macros;



function MAKE_D3D11_HRESULT(code: longword): HRESULT;
begin
    Result := MAKE_HRESULT(1, _FACD3D11, code);
end;



function MAKE_D3D11_STATUS(code: longword): HRESULT;
begin
    Result := MAKE_HRESULT(0, _FACD3D11, code);
end;



function D3D11_ENCODE_BASIC_FILTER(min, mag, mip: TD3D11_FILTER_TYPE; reduction: DWORD): TD3D11_FILTER;
begin
    Result := TD3D11_FILTER(((Ord(min) and D3D11_FILTER_TYPE_MASK) shl D3D11_MIN_FILTER_SHIFT) or ((Ord(mag) and D3D11_FILTER_TYPE_MASK) shl D3D11_MAG_FILTER_SHIFT) or
        ((Ord(mip) and D3D11_FILTER_TYPE_MASK) shl D3D11_MIP_FILTER_SHIFT) or ((reduction and D3D11_FILTER_REDUCTION_TYPE_MASK) shl D3D11_FILTER_REDUCTION_TYPE_SHIFT));
end;



function D3D11_ENCODE_ANISOTROPIC_FILTER(reduction: DWORD): TD3D11_FILTER;
begin
    Result := TD3D11_FILTER(D3D11_ANISOTROPIC_FILTERING_BIT or Ord(D3D11_ENCODE_BASIC_FILTER(D3D11_FILTER_TYPE_LINEAR, D3D11_FILTER_TYPE_LINEAR, D3D11_FILTER_TYPE_LINEAR, reduction)));
end;



function D3D11_DECODE_MIN_FILTER(d3d11Filter: DWORD): TD3D11_FILTER_TYPE;
begin
    Result := TD3D11_FILTER_TYPE((d3d11Filter shr D3D11_MIN_FILTER_SHIFT) and D3D11_FILTER_TYPE_MASK);
end;



function D3D11_DECODE_MAG_FILTER(d3d11Filter: DWORD): TD3D11_FILTER_TYPE;
begin
    Result := TD3D11_FILTER_TYPE((d3d11Filter shr D3D11_MAG_FILTER_SHIFT) and D3D11_FILTER_TYPE_MASK);
end;



function D3D11_DECODE_MIP_FILTER(d3d11Filter: DWORD): TD3D11_FILTER_TYPE;
begin
    Result := TD3D11_FILTER_TYPE((d3d11Filter shr D3D11_MIP_FILTER_SHIFT) and D3D11_FILTER_TYPE_MASK);
end;



function D3D11_DECODE_FILTER_REDUCTION(d3d11Filter: DWORD): TD3D11_FILTER_REDUCTION_TYPE;
begin
    Result := TD3D11_FILTER_REDUCTION_TYPE((d3d11Filter shr D3D11_FILTER_REDUCTION_TYPE_SHIFT) and D3D11_FILTER_REDUCTION_TYPE_MASK);
end;



function D3D11_DECODE_IS_COMPARISON_FILTER(d3d11Filter: DWORD): longbool;
begin
    Result := (D3D11_DECODE_FILTER_REDUCTION(d3d11Filter) = D3D11_FILTER_REDUCTION_TYPE_COMPARISON);
end;



function D3D11_DECODE_IS_ANISOTROPIC_FILTER(d3d11Filter: DWORD): longbool;
begin
    Result := ((d3d11Filter and D3D11_ANISOTROPIC_FILTERING_BIT) = D3D11_ANISOTROPIC_FILTERING_BIT) and (D3D11_FILTER_TYPE_LINEAR = D3D11_DECODE_MIN_FILTER(d3d11Filter)) and
        (D3D11_FILTER_TYPE_LINEAR = D3D11_DECODE_MAG_FILTER(d3d11Filter)) and (D3D11_FILTER_TYPE_LINEAR = D3D11_DECODE_MIP_FILTER(d3d11Filter));
end;




function D3D11CalcSubresource(MipSlice, ArraySlice, MipLevels: UINT): UINT;
begin
    Result := MipSlice + ArraySlice * MipLevels;
end;

{ TD3D11_VIEWPORT }

class operator TD3D11_VIEWPORT.Equal(l: TD3D11_VIEWPORT; r: TD3D11_VIEWPORT): boolean; inline;
begin
    Result := (l.TopLeftX = r.TopLeftX) and (l.TopLeftY = r.TopLeftY) and (l.Width = r.Width) and (l.Height = r.Height) and (l.MinDepth = r.MinDepth) and (l.MaxDepth = r.MaxDepth);
end;



class operator TD3D11_VIEWPORT.NotEqual(l: TD3D11_VIEWPORT; r: TD3D11_VIEWPORT): boolean; inline;
begin
    Result := not (l = r);
end;



procedure TD3D11_VIEWPORT.Init(topLeftX: single; topLeftY: single; Width: single; Height: single; minDepth: single; maxDepth: single);
begin
    Self.TopLeftX := topLeftX;
    Self.TopLeftY := topLeftY;
    Self.Width := Width;
    Self.Height := Height;
    Self.MinDepth := minDepth;
    Self.MaxDepth := maxDepth;
end;



procedure TD3D11_VIEWPORT.Init(Buffer: ID3D11Buffer; pRTView: ID3D11RenderTargetView; topLeftX: single; minDepth: single; maxDepth: single);
var
    RTVDesc: TD3D11_RENDER_TARGET_VIEW_DESC;
    NumElements: UINT = 0;
begin
    pRTView.GetDesc(@RTVDesc);
    case (RTVDesc.ViewDimension) of
        D3D11_RTV_DIMENSION_BUFFER:
            NumElements := RTVDesc.Buffer.NumElements;
    end;
    TopLeftX := topLeftX;
    TopLeftY := 0.0;
    Width := (NumElements) - topLeftX;
    Height := 1.0;
    MinDepth := minDepth;
    MaxDepth := maxDepth;
end;



procedure TD3D11_VIEWPORT.Init(pTex1D: ID3D11Texture1D; pRTView: ID3D11RenderTargetView; topLeftX: single; minDepth: single; maxDepth: single);
var
    TexDesc: TD3D11_TEXTURE1D_DESC;
    RTVDesc: TD3D11_RENDER_TARGET_VIEW_DESC;
    MipSlice: UINT = 0;
    SubResourceWidth: UINT;
begin
    pTex1D.GetDesc(@TexDesc);
    pRTView.GetDesc(@RTVDesc);
    case (RTVDesc.ViewDimension) of
        D3D11_RTV_DIMENSION_TEXTURE1D:
            MipSlice := RTVDesc.Texture1D.MipSlice;

        D3D11_RTV_DIMENSION_TEXTURE1DARRAY:
            MipSlice := RTVDesc.Texture1DArray.MipSlice;

    end;
    SubResourceWidth := TexDesc.Width div (UINT(1) shl MipSlice);
    TopLeftX := topLeftX;
    TopLeftY := 0.0;
    if SubResourceWidth <> 0 then
        Width := SubResourceWidth - topLeftX
    else
        Width := 1 - topLeftX;
    Height := 1.0;
    MinDepth := minDepth;
    MaxDepth := maxDepth;
end;



